{
  "manifest_version": 3,
  "name": "NTU COOL Text File Previewer",
  "version": "1.4",
  "description": "支援NTU COOL上多種副檔名預覽的檔案瀏覽器",
  "permissions": [
    "storage"
  ],
    "icons": {
    "16": "image/16.png",
    "32": "image/32.png",
    "48": "image/48.png",
    "128": "image/128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "image/16.png",
      "32": "image/32.png",
      "48": "image/48.png",
      "128": "image/128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://cool.ntu.edu.tw/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "css/*",
        "js/*"
      ],
      "matches": [
        "https://cool.ntu.edu.tw/*"
      ]
    }
  ]
}
