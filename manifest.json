{
  "manifest_version": 3,
  "name": "NTU COOL Text File Previewer",
  "version": "1.3",
  "description": "支援自訂副檔名預覽分類的檔案瀏覽器",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cool.ntu.edu.tw/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "css/*",
        "js/*"
      ],
      "matches": [
        "https://cool.ntu.edu.tw/*"
      ]
    }
  ]
}
